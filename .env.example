# TradingCoach 环境变量配置
# 复制此文件为 .env 并填入你的配置

# ==================== 基础配置 ====================
# DEBUG=true 会暴露 /api/v1/docs + /api/v1/openapi.json — 生产务必 false
DEBUG=false
LOG_LEVEL=INFO

# ==================== 安全：生产必填 ====================
# 前端允许跨域来源（逗号分隔多个）。切勿用 "*"，与 credentials=True 同用
# 会让任意站点借用户 cookie 调用敏感端点。
# 本地开发不用填，代码已内置 localhost 白名单。
CORS_ORIGINS=

# 管理员 token：配置后 DELETE /api/v1/system/data/reset 除
# X-Confirm-Reset header 外还需匹配的 X-Admin-Token。
# 建议用：openssl rand -hex 32
ADMIN_TOKEN=

# ==================== 数据库 ====================
# 本地开发: sqlite:///./data/tradingcoach.db
# Docker 部署: sqlite:////app/data/tradingcoach.db
# DATABASE_URL=sqlite:////app/data/tradingcoach.db

# ==================== LLM 配置 (AI Coach) ====================
# 至少配置其中一个即可启用 AI 对话功能

# Anthropic Claude API (推荐)
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API (备选)
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ==================== 数据源 API ====================

# Alpha Vantage - 股票数据
ALPHA_VANTAGE_API_KEY=

# Polygon.io - 期权 Greeks
POLYGON_API_KEY=

# Tiingo - 基本面数据
TIINGO_API_KEY=

# NewsAPI - 新闻数据
NEWS_API_KEY=

# Tavily - 新闻搜索
TAVILY_API_KEY=

# ==================== 邮件通知 (可选) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tradingcoach.com

# ==================== 网络配置 ====================
# 新闻搜索网络区域: international / china / auto
NEWS_NETWORK_REGION=auto
